# Solar Portal - Environment Configuration Example
# Copy this file to .env and fill in your values

# ============== Backend Configuration ==============
# Server
BACKEND_PORT=5000
BACKEND_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solar_portal
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=solar_portal

# JWT & Sessions
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
REFRESH_TOKEN_SECRET=your-super-secret-refresh-key-min-32-chars
SESSION_SECRET=your-super-secret-session-key-min-32-chars

# Cookies
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# Leave empty when using a tunnel hostname you do not control.
COOKIE_DOMAIN=
COOKIE_MAX_AGE=2592000000

# Email Configuration (optional for MVP, required for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@solarportal.com

# Email Verification
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_EXPIRY=86400

# Password Reset
PASSWORD_RESET_EXPIRY=3600
PASSWORD_RESET_EMAIL_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# CORS
# For tunnels without your own domain, use the generated https origin here.
CORS_ORIGIN=http://localhost:3000
STRICT_CORS=false

# ============== Frontend Configuration ==============
FRONTEND_PORT=3000
# For production behind reverse proxy or a tunnel prefer /api.
VITE_API_BASE_URL=http://localhost:5000/api

# ============== Agent Configuration ==============
AGENT_PORT=3001

# Home Assistant (local, on Raspberry)
HA_URL=http://localhost:8123
HA_TOKEN=your-long-lived-access-token-never-share

# Cloud Backend
# Can also be a tunnel URL, for example https://random-subdomain.trycloudflare.com/api
CLOUD_API_URL=https://yourdomain.com/api
DEVICE_TOKEN=generated-during-pairing

# Data Collection
POLLING_INTERVAL=30000
BATCH_SIZE=10
MAX_RETRIES=3
RETRY_DELAY=5000

# ============== Docker Compose ==============
COMPOSE_PROJECT_NAME=solar_portal

# Database (Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=solar_portal
