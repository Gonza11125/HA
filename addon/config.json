{
  "name": "Solar Portal",
  "version": "0.1.0",
  "slug": "solar_portal",
  "description": "Secure web customer portal for Home Assistant solar installations",
  "url": "https://github.com/Gonza11125/solar-portal-addon",
  "arch": ["aarch64", "armhf", "armv7", "amd64", "i386"],
  "startup": "application",
  "boot": "auto",
  "ports": {
    "3000/tcp": 3000,
    "5000/tcp": 5000
  },
  "ports_description": {
    "3000/tcp": "Frontend (React)",
    "5000/tcp": "Backend API (Express)"
  },
  "options": {
    "log_level": "info",
    "ha_url": "http://supervisor/core",
    "frontend_port": 3000,
    "backend_port": 5000
  },
  "schema": {
    "log_level": "list(trace|debug|info|notice|warning|error|fatal)?",
    "ha_url": "url",
    "frontend_port": "port",
    "backend_port": "port"
  }
}
